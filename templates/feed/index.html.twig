{% extends 'base.html.twig' %}

{% block title %}INSAT Pulse - Feed{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">

        <div class="col-md-3">
            <div class="card">
                <div class="card-header" style="background-color:#8F1402; color:white;">
                    <h5 class="mb-0">Upcoming Schedule</h5>
                </div>
                <div class="card-body">
                    {% if upcoming is empty %}
                        <p class="text-muted">No liked upcoming events yet.</p>
                    {% else %}
                        {% for ev in upcoming %}
                            <div class="mb-2">
                                <strong>{{ ev.title }}</strong><br>
                                <small>{{ ev.eventDate|date('d/m/Y') }}</small>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-md-9">
            {% if events is empty %}
                <p>No posts yet.</p>
            {% else %}
                {% for event in events %}
                    {% set isLiked = student ? likeRepo.findOneBy({'student': student, 'event': event}) : false %}
                    {% set isPast  = event.eventDate < now %}

                    <div class="card mb-3 border-0 shadow-sm" style="border-radius:15px;">
                        {% if event.image %}
                            <img src="{{ asset('uploads/' ~ event.image) }}" class="card-img-top" style="max-height:300px; object-fit:cover; border-radius:15px 15px 0 0;">
                        {% endif %}
                        <div class="card-body">
                            <h5 class="fw-bold">{{ event.title }}</h5>

                            {% if isPast %}
                                <span class="badge mb-2" style="background-color:#8F1402;">
                                    <i class="bi bi-clock-history me-1"></i> Event already passed
                                </span>
                            {% endif %}

                            <p>{{ event.description }}</p>
                            <small>
                                <span style="color:#8F1402; font-weight:600;">
                                    {{ event.club.name }}
                                </span> |
                                {{ event.eventDate|date('Y-m-d H:i') }}
                            </small>

                            <div class="d-flex gap-2 mt-2">
                                <form action="{{ path('app_like', {id: event.id}) }}" method="POST">
                                    <input type="hidden" name="_token" value="{{ csrf_token('like' ~ event.id) }}">
                                    <button type="submit" class="btn btn-sm" style="background-color:#8F1402; color:white;">
                                        {{ isLiked ? '❤️ Unlike' : '🤍 Like' }}
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}
        </div>

    </div>
</div>
{% endblock %}