{% extends 'base.html.twig' %}

{% block title %}{{ event.title }} — INSAT Pulse{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/student.css') }}">
    <link rel="stylesheet" href="{{ asset('css/event.css') }}">
{% endblock %}

{% block body %}
<div class="page-body">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">

            {% include 'partials/_event_card.html.twig' with {
                event:       event,
                isOwner:     false,
                isFeed:      true,
                isLiked:     hasLiked,
                isFollowing: isFollowing,
                isDetail:    true
            } %}

            <div class="mt-3">
            {% if is_granted('ROLE_STUDENT') %}
                <a href="{{ path('app_home') }}" class="ec-btn ec-btn-edit">
                    <i class="bi bi-arrow-left"></i> Back to feed
                </a>
            {% else %}
                <a href="{{ path('club_feed') }}" class="ec-btn ec-btn-edit">
                    <i class="bi bi-arrow-left"></i> Back to feed
                </a>
            {% endif %}
            </div>

        </div>
    </div>
</div>
{% endblock %}
