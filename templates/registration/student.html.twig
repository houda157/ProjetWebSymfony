{% extends 'base.html.twig' %}

{% block title %}INSAT Pulse - Register Student{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/register.css') }}">
{% endblock %}

{% block body %}
    <main class="register-shell">
        <div class="register-panel">
            <section class="register-left">
                <div class="form-container">
                    <div class="register-logo">
                        <img src="{{ asset('images/logo.png') }}" alt="INSAT Pulse Logo">
                    </div>

                    <h1 class="form-title">Create a student account</h1>

                    {% for error in form.vars.errors %}
                        <small class="form-error">{{ error.message }}</small>
                    {% endfor %}

                    {{ form_start(form, { 'attr': { 'class': 'registration-form' } }) }}
                        <div class="form-group">
                            {{ form_label(form.fullname) }}
                            {{ form_widget(form.fullname) }}
                            {% for error in form.fullname.vars.errors %}
                                <small class="form-error">{{ error.message }}</small>
                            {% endfor %}
                        </div>

                        <div class="form-group">
                            {{ form_label(form.username) }}
                            {{ form_widget(form.username) }}
                            {% for error in form.username.vars.errors %}
                                <small class="form-error">{{ error.message }}</small>
                            {% endfor %}
                        </div>

                        <div class="form-group">
                            {{ form_label(form.email) }}
                            {{ form_widget(form.email) }}
                            {% for error in form.email.vars.errors %}
                                <small class="form-error">{{ error.message }}</small>
                            {% endfor %}
                        </div>

                        <div class="form-group">
                            {{ form_label(form.plainPassword.first) }}
                            {{ form_widget(form.plainPassword.first) }}
                            <small id="password-weak" class="form-error form-hint">Password must have at least 8 characters.</small>
                            {% for error in form.plainPassword.first.vars.errors %}
                                <small class="form-error">{{ error.message }}</small>
                            {% endfor %}
                        </div>

                        <div class="form-group">
                            {{ form_label(form.plainPassword.second) }}
                            {{ form_widget(form.plainPassword.second) }}
                            <small id="password-mismatch" class="form-error form-hint">Verify your password.</small>
                            {% for error in form.plainPassword.second.vars.errors %}
                                <small class="form-error">{{ error.message }}</small>
                            {% endfor %}
                            {% for error in form.plainPassword.vars.errors %}
                                <small class="form-error">{{ error.message }}</small>
                            {% endfor %}
                        </div>

                        <button type="submit" class="submit-btn">Create</button>
                    {{ form_end(form) }}

                    <p class="auth-switch">
                        Already have an account?
                        <a href="{{ path('app_login') }}">Login now</a>
                    </p>
                </div>
            </section>

            <section class="register-right">
                <h2>WHERE TODAY'S IDEAS TURN<br>INTO TOMORROW'S REALITY</h2>
            </section>
        </div>
    </main>
{% endblock %}

{% block javascripts %}
    <script>
        const passwordInput = document.getElementById('{{ form.plainPassword.first.vars.id }}');
        const repeatInput = document.getElementById('{{ form.plainPassword.second.vars.id }}');
        const weakMessage = document.getElementById('password-weak');
        const mismatchMessage = document.getElementById('password-mismatch');

        function validatePasswordPreview() {
            weakMessage.style.display = passwordInput.value.length > 0 && passwordInput.value.length < 8 ? 'block' : 'none';
            mismatchMessage.style.display = repeatInput.value.length > 0 && passwordInput.value !== repeatInput.value ? 'block' : 'none';
        }

        passwordInput.addEventListener('input', validatePasswordPreview);
        repeatInput.addEventListener('input', validatePasswordPreview);
    </script>
{% endblock %}
