{% extends 'base.html.twig' %}

{% block title %}INSAT Pulse – Feed{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/student.css') }}">
    <link rel="stylesheet" href="{{ asset('css/event.css') }}">
{% endblock %}

{% block body %}
<div class="page-body">
    <div class="row g-4">

        {# ── EVENTS FEED ────────────────────────────────────── #}
        <div class="col-12 col-lg-8">

            {% if events is empty %}
                <div class="blank-panel">
                    <i class="bi bi-megaphone text-secondary feed-blank-icon"></i>
                    <span class="text-secondary">No posts yet.</span>
                </div>
            {% else %}
                {% for event in events %}
                    {% set isLiked     = event.id in likedEventIds %}
                    {% set isFollowing = event.club.user.id in followedClubUserIds %}
                    {% include 'partials/_event_card.html.twig' with {
                        event:       event,
                        isOwner:     false,
                        isFeed:      true,
                        isLiked:     isLiked,
                        isFollowing: isFollowing
                    } %}
                {% endfor %}
            {% endif %}

        </div>

        {# ── SIDEBAR: UPCOMING ──────────────────────────────── #}
        <div class="col-12 col-lg-4">
            <div class="sidebar-card upcoming-sidebar">

                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="panel-icon-block">
                        <i class="bi bi-calendar-event-fill"></i>
                    </div>
                    <span class="panel-title upcoming-heading">Upcoming</span>
                </div>

                {% if upcoming is empty %}
                    <p class="text-muted upcoming-hint">
                        Like events to see your upcoming schedule here.
                    </p>
                {% else %}
                    <div class="d-flex flex-column gap-2">
                        {% for ev in upcoming %}
                            <a href="{{ path('event_show', {id: ev.id}) }}" class="upcoming-link">
                                <div class="upcoming-item">
                                    <div class="upcoming-item-title">{{ ev.title }}</div>
                                    <div class="upcoming-item-date">
                                        <i class="bi bi-calendar3"></i>
                                        {{ ev.eventDate|date('d/m/Y · H:i') }}
                                    </div>
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}

            </div>
        </div>

    </div>
</div>
{% endblock %}
