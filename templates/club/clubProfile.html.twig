<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>INSAT Pulse – {{ club.name }}</title>

    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

<link rel="stylesheet" href="/css/club.css">
</head>

<body style="background: linear-gradient(135deg, #fde8e0 0%, #f9d5d3 40%, #f5c6c8 100%); min-height: 100vh;">


    <div class="page-body">
        <div class="row g-4">

            {# ── SIDEBAR GAUCHE ──────────────────────────────────────────── #}
            <div class="col-12 col-md-4 col-lg-3">
                <div class="sidebar-card">

                    <div class="club-avatar">
                        {# Remplace : $club['cover_img'] ?: 'https://placehold.co/...' #}
                        <img src="{{ club.coverImg ?: 'https://placehold.co/110x110?text=Logo' }}" alt="Logo">
                    </div>

                    {# Remplace : htmlspecialchars($club['name']) — Twig échappe automatiquement #}
                    <div class="club-name">{{ club.name }}</div>
                    <div class="club-handle">@{{ club.user.username }}</div>

                    <div class="stats-row">
                        <div class="stat-item">
                            {# Remplace : $followers->num_rows
                               followers est une Collection Doctrine → |length donne le count #}
                            <div class="stat-num">{{ followers|length }}</div>
                            <div class="stat-lbl">Followers</div>
                        </div>
                        <div class="stat-item">
                            {# Remplace : $events->num_rows #}
                            <div class="stat-num">{{ events|length }}</div>
                            <div class="stat-lbl">Posts</div>
                        </div>
                    </div>

                    {# Remplace : htmlspecialchars($club['description'] ?? 'No bio available.') #}
                    <p class="club-bio">{{ club.description ?: 'No bio available.' }}</p>

                    <div class="sidebar-nav">
                        {# Remplace : <?php if($is_owner): ?> #}
                        {#% if isOwner %#}
                            <button class="nav-btn" data-panel="profile" onclick="switchPanel(this)">
                                <i class="bi bi-person"></i> Profile
                            </button>
                        {#% endif %#}
                        <button class="nav-btn active" data-panel="myposts" onclick="switchPanel(this)">
                            <i class="bi bi-pencil-square"></i> My posts
                        </button>
                        <button class="nav-btn" data-panel="calendar" onclick="switchPanel(this)">
                            <i class="bi bi-bookmark"></i> My calendar
                        </button>
                    </div>

                </div>
            </div>

            {# ── CONTENU PRINCIPAL ───────────────────────────────────────── #}
            <div class="col-12 col-md-8 col-lg-9">
                <div class="content-card">

                    {# ══ PANEL : MY POSTS ══════════════════════════════════ #}
                    <div id="panel-myposts">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2 style="font-weight:800; margin:0; color:#1a1a1a; font-size:1.4rem;">Club Feed</h2>
                            <div class="d-flex gap-2">

                                {# Remplace :
                                   if (isset($_SESSION['user']) && $_SESSION['user']['id'] == $club_id)
                                   app.user → l'utilisateur connecté (équivalent $_SESSION['user']) #}
                                {% if app.user and app.user.id == club.user.id %}
                                    {# path() remplace href="create-event.php" #}
                                    <a href="{{ path('event_create_form') }}" class="btn-maroon" style="text-decoration:none;">
                                        <i class="bi bi-plus-lg me-1"></i> Add post
                                    </a>
                                {% endif %}

                                {#% if isOwner %#}
                                    <button class="btn-action"><i class="bi bi-bell"></i> Requests</button>
                                    <button class="btn-action"><i class="bi bi-plus-lg"></i> add post</button>
                                {#% endif %#}
                                
                            </div>
                        </div>

                        <div id="posts-feed">
                            {# Remplace : if ($events->num_rows > 0): while ($e = $events->fetch_assoc()): #}
                            {% if events|length > 0 %}
                                {% for e in events %}
                                    <div class="card mb-3 border-0 shadow-sm" style="border-radius:15px; overflow:hidden;">

                                        {# Remplace : <?php if (!empty($e['image'])): ?> #}
                                        {% if e.image %}
                                            {# asset() génère l'URL publique vers public/uploads/... #}
                                            <img src="{{ asset('uploads/' ~ e.image) }}"
                                                 class="card-img-top"
                                                 style="max-height:300px; object-fit:cover;">
                                        {% endif %}

                                        <div class="card-body">
                                            <h5 class="fw-bold">{{ e.title }}</h5>
                                            <p class="text-muted small">
                                                <i class="bi bi-geo-alt"></i> {{ e.place }} |
                                                <i class="bi bi-clock"></i>
                                                {# Remplace : $e['event_date']
                                                   Twig formate un objet DateTime avec le filtre date() #}
                                                {{ e.eventDate|date('Y-m-d') }}
                                            </p>
                                            <p>{{ e.description }}</p>
                                        </div>
                                    </div>
                                {% endfor %}
                            {% else %}
                                <div class="blank-panel">
                                    <i class="bi bi-megaphone text-secondary" style="font-size:2.5rem;"></i>
                                    <span class="text-secondary mt-2">No posts published yet.</span>
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    {# ══ PANEL : CALENDAR ══════════════════════════════════ #}
                    <div id="panel-calendar" class="d-none">
                        <div class="d-flex align-items-center gap-3 mb-4">
                            <div style="background:#fbeaea; padding:10px; border-radius:12px;">
                                <i class="bi bi-calendar3" style="color:#8B0000; font-size:1.5rem;"></i>
                            </div>
                            <h2 style="font-weight:800; margin:0; color:#1a1a1a; font-size:1.4rem;">My Calendar</h2>
                        </div>
                        <div id="calendar"></div>
                    </div>

                    {# ══ PANEL : PROFILE SETTINGS ══════════════════════════ #}
                    {#% if isOwner %#}
                    <div id="panel-profile" class="d-none">
                        <div class="d-flex align-items-center gap-3 mb-4">
                            <div style="background:#fbeaea; padding:10px; border-radius:12px;">
                                <i class="bi bi-person-circle" style="color:#8B0000; font-size:1.5rem;"></i>
                            </div>
                            <h2 style="font-weight:800; margin:0; color:#1a1a1a; font-size:1.4rem;">Profile Settings</h2>
                        </div>

                        {# Remplace : if (isset($_GET['success'])): #}
                        {% if app.request.query.has('success') %}
                            <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
                                <i class="bi bi-check-circle me-2"></i> Profile updated successfully!
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        {% endif %}

                        {# Remplace : <form action="club.php" method="POST" enctype="multipart/form-data">
                           path('club_edit', {id: club.user.id}) génère /club/{id}/edit #}
                        <form action="{{ path('club_edit', {id: club.user.id}) }}"
                              method="POST"
                              enctype="multipart/form-data">

                            {# Remplace : <input type="hidden" name="action" value="update_profile">
                               Plus besoin en Symfony — chaque route a sa propre URL #}

                            {# Jeton CSRF anti-falsification — Symfony l'exige en POST #}
                            <input type="hidden" name="_token" value="{{ csrf_token('club_edit') }}">

                            {# Profile Image #}
                            <div class="text-center mb-4">
                                <img src="{{ club.user.profileImg ?: 'https://placehold.co/120x120?text=Profile' }}"
                                     alt="Profile"
                                     class="rounded-circle mb-3"
                                     style="width:120px; height:120px; object-fit:cover; border:3px solid #8F1402;">
                                <div class="mb-3">
                                    <label for="profile_img" class="form-label fw-semibold text-muted">Change Profile Image</label>
                                    <input type="file" name="profile_img" id="profile_img" class="form-control" accept="image/*">
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="name" class="form-label fw-semibold text-muted">Club Name</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-pencil"></i></span>
                                        {# Remplace : value="<?php echo htmlspecialchars($club['name']); ?>" #}
                                        <input type="text" name="name" id="name"
                                               class="form-control"
                                               value="{{ club.name }}" required>
                                    </div>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label for="category" class="form-label fw-semibold text-muted">Category</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-tag"></i></span>
                                        <input type="text" name="category" id="category"
                                               class="form-control"
                                               value="{{ club.category ?? '' }}">
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="description" class="form-label fw-semibold text-muted">Description</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-card-text"></i></span>
                                    <textarea name="description" id="description"
                                              class="form-control" rows="4">{{ club.description ?? '' }}</textarea>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="cover_img" class="form-label fw-semibold text-muted">Cover Image</label>
                                {% if club.coverImg %}
                                    <div class="mb-2">
                                        <img src="{{ club.coverImg }}" alt="Cover"
                                             class="img-fluid rounded-3"
                                             style="max-height:150px; object-fit:cover;">
                                    </div>
                                {% endif %}
                                <input type="file" name="cover_img" id="cover_img" class="form-control" accept="image/*">
                            </div>

                            <div class="d-grid mt-4 mb-3">
                                <button type="submit" class="btn btn-lg fw-bold"
                                        style="background-color:#8F1402; color:#fff;">
                                    <i class="bi bi-check-lg me-2"></i> Save Changes
                                </button>
                            </div>
                        </form>
                    </div>
                    {#% endif %#}

                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let calendarRendered = false;

        function switchPanel(btn) {
            document.querySelectorAll('.sidebar-nav .nav-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            document.getElementById('panel-myposts').classList.add('d-none');
            document.getElementById('panel-calendar').classList.add('d-none');
            {% if isOwner %}
            document.getElementById('panel-profile').classList.add('d-none');
            {% endif %}

            document.getElementById('panel-' + btn.dataset.panel).classList.remove('d-none');

            if (btn.dataset.panel === 'calendar' && !calendarRendered) {

                {# Remplace le bloc PHP qui construisait le JSON pour FullCalendar :
                   json_encode([['title'=>$e['title'], 'start'=>$e['event_date'], 'color'=>'#8F1402']])
                   Twig fait la même chose avec le filtre |json_encode #}
                const calendarEvents = {{ events|map(e => {
                    'title': e.title,
                    'start': e.eventDate|date('Y-m-d'),
                    'color': '#8F1402'
                })|json_encode|raw }};

                var calendar = new FullCalendar.Calendar(document.getElementById('calendar'), {
                    initialView: 'dayGridMonth',
                    displayEventTime: false,
                    events: calendarEvents
                });
                calendar.render();
                calendarRendered = true;
            }
        }
    </script>
</body>
</html>
