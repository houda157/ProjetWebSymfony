{# templates/home/club_feed.html.twig
   Feed d'accueil du club — événements de tous les clubs (multi-clubs).
   Remplace : club-feed.php

   isFeed: true → chaque carte montre le nom + logo du club qui a posté.
   isOwner: calculé PAR ÉVÉNEMENT — true uniquement si l'event appartient
            au club connecté (→ boutons Edit/Delete), false sinon. #}

{% extends 'base.html.twig' %}

{% block title %}INSAT Pulse - Home{% endblock %}

{% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('css/club.css') }}">
    <link rel="stylesheet" href="{{ asset('css/event.css') }}">
{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-8">
                {% if events is not empty %}

                    {% for event in events %}
                        {% include 'partials/_event_card.html.twig' with {
                            event: event,
                            isOwner: (app.user and event.club.user.id == app.user.id),
                            isFeed: true
                        } %}
                    {% endfor %}

                {% else %}
                    <div class="text-center mt-5">
                        <i class="bi bi-megaphone text-secondary" style="font-size:2.5rem;"></i>
                        <p class="text-muted mt-2">No posts yet.</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
