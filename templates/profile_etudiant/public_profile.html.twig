{% extends 'base.html.twig' %}

{% block title %}{{ student.fullname }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card p-4 text-center rounded-4">

                <img src="{{ student.user.profileImg ? '/uploads/' ~ student.user.profileImg : '/images/default.png' }}"
                     class="rounded-circle mx-auto d-block mb-3"
                     style="width:110px; height:110px; object-fit:cover; border:2px solid #8B0000;">

                <h4 class="fw-bold">{{ student.fullname }}</h4>
                <p class="text-muted">{{ student.user.email }}</p>

                {% if student.major %}
                    <p> {{ student.major }}</p>
                {% endif %}

                <h6 class="fw-bold">Followed Clubs</h6>
                {% for follow in student.follows %}
                    <p>
                        <a href="{{ path('club_show', {id: follow.club.user.id}) }}">
                            {{ follow.club.name }}
                        </a>
                    </p>
                {% else %}
                    <p class="text-muted">No clubs followed yet.</p>
                {% endfor %}

            </div>
        </div>
    </div>
</div>
{% endblock %}