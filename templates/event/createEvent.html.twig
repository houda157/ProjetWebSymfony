{# templates/event/new.html.twig
   Formulaire de création d'événement.
   Remplace : public/create-event.php #}

{% extends 'base.html.twig' %}

{% block title %}Create Event - INSAT Pulse{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/event.css') }}">
{% endblock %}

{% block body %}
<div class="page-body">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">

            <div class="content-card">

                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="panel-icon-block">
                        <i class="bi bi-megaphone-fill"></i>
                    </div>
                    <h2 class="panel-title">Publish New Event</h2>
                </div>

                {#
                Form rendering — Symfony génère automatiquement :
                  • le <form> avec method="POST"
                  • enctype="multipart/form-data" (car il y a un FileType)
                  • le token CSRF caché
                #}
                {{ form_start(form) }}

                    <div class="row g-4">

                        {# ── Title (largeur complète) ───────────────────────── #}
                        <div class="col-12">
                            <label class="form-label">
                                <i class="bi bi-type"></i> Event Title
                            </label>
                            {{ form_widget(form.title, {
                                attr: {
                                    'class': 'form-control',
                                    'placeholder': 'Enter a catchy title'
                                }
                            }) }}
                            {{ form_errors(form.title) }}
                        </div>

                        {# ── Location + Date (côte à côte) ──────────────────── #}
                        <div class="col-md-6">
                            <label class="form-label">
                                <i class="bi bi-geo-alt"></i> Location
                            </label>
                            {{ form_widget(form.place, {
                                attr: {
                                    'class': 'form-control',
                                    'placeholder': 'Where is it?'
                                }
                            }) }}
                            {{ form_errors(form.place) }}
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">
                                <i class="bi bi-calendar-check"></i> Event Date
                            </label>
                            {{ form_widget(form.eventDate, {
                                attr: {
                                    'class': 'form-control'
                                }
                            }) }}
                            {{ form_errors(form.eventDate) }}
                        </div>

                        {# ── Description (largeur complète) ─────────────────── #}
                        <div class="col-12">
                            <label class="form-label">
                                <i class="bi bi-justify-left"></i> Description
                            </label>
                            {{ form_widget(form.description, {
                                attr: {
                                    'class': 'form-control',
                                    'rows': 4,
                                    'placeholder': 'Tell the students what to expect...'
                                }
                            }) }}
                            {{ form_errors(form.description) }}
                        </div>

                        {# ── Event Poster (zone de drop stylée) ─────────────── #}
                        <div class="col-12">
                            <label class="form-label">
                                <i class="bi bi-image"></i> Event Poster
                            </label>

                            {# Label cliquable qui sert de zone d'upload visuelle #}
                            <label class="photo-upload-label" for="photoInput"
                                   style="height: 120px; flex-direction: column; justify-content: center;">
                                <i class="bi bi-cloud-arrow-up" style="font-size: 2rem;"></i>
                                <span id="photoLabel">Click to upload your image</span>
                            </label>

                            {# Input file caché — déclenché par le clic sur le label ci-dessus #}
                            {{ form_widget(form.imageFile, {
                                attr: {
                                    'id': 'photoInput',
                                    'accept': 'image/*',
                                    'style': 'display: none;'
                                }
                            }) }}
                            {{ form_errors(form.imageFile) }}
                        </div>

                        {# ── Boutons Cancel / Publish ───────────────────────── #}
                        <div class="col-12 d-flex justify-content-end gap-3 pt-3">
                            {# Remplace : <a href="club.php?id=<?= $_SESSION['user']['id'] ?>"> #}
                            <a href="{{ path('club_show', {id: app.user.id}) }}"
                               class="btn-cancel" style="text-decoration: none;">
                                Cancel
                            </a>
                            <button type="submit" class="btn-maroon">
                                <i class="bi bi-send-fill me-2"></i>Publish Post
                            </button>
                        </div>

                    </div>

                    {# Rend les champs restants (CSRF token, etc.) #}
                    {{ form_rest(form) }}

                {{ form_end(form) }}

            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    <script>
        // Mise à jour du label quand l'utilisateur sélectionne un fichier
        const photoInput = document.getElementById('photoInput');
        if (photoInput) {
            photoInput.addEventListener('change', function () {
                document.getElementById('photoLabel').textContent =
                    this.files[0] ? this.files[0].name : 'Click to upload your image';
            });
        }
    </script>
{% endblock %}
