{# templates/event/new.html.twig
   Formulaire de création d'événement.
   Remplace : public/create-event.php #}

{% extends 'base.html.twig' %}

{% block title %}New Event – INSAT Pulse{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/event.css') }}">
{% endblock %}

{% block body %}
<div class="page-body">
    <div class="content-card" style="max-width:700px; margin:0 auto;">

        <div class="d-flex align-items-center gap-3 mb-4">
            <div class="panel-icon-block">
                <i class="bi bi-megaphone-fill"></i>
            </div>
            <h2 class="panel-title">Create a new event</h2>
        </div>

        {#
        Form rendering — Symfony génère :
          • le <form> avec method="POST"
          • enctype="multipart/form-data" (car il y a un FileType)
          • le token CSRF caché
        #}
        {{ form_start(form) }}

            <div class="mb-3">
                {{ form_row(form.title) }}
            </div>

            <div class="mb-3">
                {{ form_row(form.description) }}
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    {{ form_row(form.eventDate) }}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_row(form.place) }}
                </div>
            </div>

            <div class="mb-3">
                {{ form_row(form.imageFile) }}
            </div>

            <div class="d-flex gap-2 mt-4">
                {# Bouton Annuler → retour vers la page du club connecté #}
                <a href="{{ path('club_show', {id: app.user.id}) }}" class="btn btn-secondary">
                    Cancel
                </a>
                <button type="submit" class="btn btn-lg btn-save flex-grow-1">
                    <i class="bi bi-check-lg me-2"></i> Publish Event
                </button>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
