{% extends 'base.html.twig' %}

{% block title %}Create Event - INSAT Pulse{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/club.css') }}">
    <link rel="stylesheet" href="{{ asset('css/event.css') }}">
{% endblock %}

{% block body %}
<div class="page-body">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="content-card">

                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="panel-icon-block">
                        <i class="bi bi-megaphone-fill"></i>
                    </div>
                    <h2 class="panel-title">Publish New Event</h2>
                </div>

                {{ form_start(form, { attr: { enctype: 'multipart/form-data' } }) }}

                    <div class="row g-4">
                        <div class="col-12">{{ form_row(form.title) }}</div>
                        <div class="col-md-6">{{ form_row(form.place) }}</div>
                        <div class="col-md-6">{{ form_row(form.eventDate) }}</div>
                        <div class="col-12">{{ form_row(form.description) }}</div>

                        <div class="col-12">
                            <label class="photo-upload-label" for="{{ form.imageFile.vars.id }}"
                                   style="height:120px; flex-direction:column; justify-content:center;">
                                <i class="bi bi-cloud-arrow-up" style="font-size:2rem;"></i>
                                <span id="photoLabel">Click to upload your image</span>
                            </label>
                            {{ form_widget(form.imageFile, { attr: { accept: 'image/*', style: 'display:none;' } }) }}
                            {{ form_errors(form.imageFile) }}
                        </div>

                        <div class="col-12 d-flex justify-content-end gap-3 pt-3">
                            <a href="{{ path('club_show', {id: app.user.id}) }}" class="btn-cancel" style="text-decoration:none;">Cancel</a>
                            <button type="submit" class="btn-maroon">
                                <i class="bi bi-send-fill me-2"></i>Publish Post
                            </button>
                        </div>
                    </div>

                    {{ form_rest(form) }}
                {{ form_end(form) }}

            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    const photoInput = document.getElementById('{{ form.imageFile.vars.id }}');
    if (photoInput) {
        photoInput.addEventListener('change', function () {
            document.getElementById('photoLabel').textContent =
                this.files[0] ? this.files[0].name : 'Click to upload your image';
        });
    }
</script>
{% endblock %}
